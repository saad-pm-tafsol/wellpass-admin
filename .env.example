# ──────────────────────────────────────────────────────────────────────────
# WellPass Admin — environment configuration
# Copy this file to `.env.local` and adjust the values. `.env.local` is
# git-ignored so your real credentials are never committed.
# ──────────────────────────────────────────────────────────────────────────

# Dedicated admin login. These are the ONLY credentials that can sign in to
# the admin portal. Change them before deploying anywhere public.
ADMIN_EMAIL=12345678@gmail.com
ADMIN_PASSWORD=12345678

# Secret used to sign the session cookie (HMAC-SHA256). Use a long, random
# string in production — e.g. `openssl rand -base64 48`.
SESSION_SECRET=change-me-to-a-long-random-secret-string-please

# How long an admin session stays valid, in seconds (default: 8 hours).
SESSION_MAX_AGE=28800

# Public site origin used to build absolute metadata URLs. No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
